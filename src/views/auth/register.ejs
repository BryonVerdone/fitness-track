<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Register' }) %></head>
<body>
  <div class="auth-wrap card">
    <h1><%= firstUser ? 'Create admin account' : 'Create account' %></h1>
    <% if (firstUser) { %><p class="muted">You're the first user — this account becomes the admin.</p><% } %>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="<%= firstUser ? '/register' : '/register/' + code %>">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" required autofocus>
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required>
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="8">
      <button type="submit">Create account</button>
    </form>
  </div>
</body>
</html>
